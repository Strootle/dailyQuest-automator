{
    "manifest_version": 3,
    "name": "Daily Quest",
    "version": "1.0",
    "description": "A Chrome extension that provides daily quests for automation purposes.",
    "permissions": [
        "storage",
        "notifications",
        "activeTab",
        "alarms",
        "tabs",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}